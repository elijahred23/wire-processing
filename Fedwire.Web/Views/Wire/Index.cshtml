@model WireRequestViewModel
<h2>Wire Transfer</h2>

<form method="post" asp-action="Submit">
    <input asp-for="ClientReferenceId" placeholder="Client Reference Id" />
    <br />
    <input asp-for="Amount" placeholder="Amount" />
    <br />

    <input asp-for="CurrencyCode" value="USD" />
    <br />

    <select asp-for="DebtorAccountNumber">
    @foreach (var account in ViewBag.Accounts)
    {
        <option value="@account.AccountNumber">
            @account.AccountNumber (@account.Balance)
        </option>
    }
    </select>

    <button type="submit">Submit Wire</button>
</form>

@if (ViewBag.Message != null)
{
    <p>@ViewBag.Message</p>
}